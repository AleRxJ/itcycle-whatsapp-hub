# Example environment variables file
# Copy this to .env and fill in your values

# WhatsApp Cloud API Configuration
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token_here
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# JWT Security
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# Database (if not using docker-compose values)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=whatsapp_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ (if not using docker-compose values)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis (if not using docker-compose values)
REDIS_HOST=localhost
REDIS_PORT=6379

# n8n Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_ENABLED=true

# Application Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod
